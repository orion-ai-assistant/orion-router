# ===========================================================================
# Orion Router Servisi - Ortam Değişkenleri Örneği (.env.example)
# ===========================================================================

# --- Router (bu servis) ---
ROUTER_HOST=0.0.0.0
# Uvicorn / docker-compose portu (production ve `docker compose up`).
ROUTER_PORT=20128
# Yerel hybrid dev (dev.ps1); ayarlanmazsa 20129 kullanılır.
ROUTER_DEV_PORT=20129

# --- Yerel Servis Adresleri ---
LLM_HOST=127.0.0.1
LLM_PORT=8080

EMBED_HOST=127.0.0.1
EMBED_PORT=8080

TTS_HOST=127.0.0.1
TTS_PORT=8808

# --- Admin Paneli ---
# Sağlayıcı API anahtarları .env'de tutulmaz; Dashboard → Key Pool üzerinden eklenir.
# Router admin paneli (/admin) için kimlik doğrulama anahtarı (X-Admin-Key başlığı ile gönderilir)
ADMIN_SECRET=orion-admin

# --- Veritabanı (PostgreSQL) ---
POSTGRES_HOST=router-db
POSTGRES_PORT=5432
POSTGRES_DB=orion_router
POSTGRES_USER=router_user
POSTGRES_PASSWORD=router_pass

# --- Dashboard UI ---
DASHBOARD_OUT_DIR=dashboard/out
