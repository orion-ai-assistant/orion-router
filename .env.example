# ===========================================================================
# Orion Router Servisi - Ortam Değişkenleri Örneği (.env.example)
# ===========================================================================

# --- Yerel Servis Adresleri ---
# Eğer bu servis Docker dışında çalışıyorsa, host olarak 'localhost' yazabilirsiniz.
LLM_HOST=llama-cpp
LLM_PORT=8080

EMBED_HOST=llama-cpp-embed
EMBED_PORT=8080

TTS_HOST=tts
TTS_PORT=8808

# --- Dış Servis API Anahtarları ve Adresleri ---
# OpenRouter Ayarları
OPENROUTER_BASE_URL=https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI Ayarları
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Gemini Ayarları
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Ayarları
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Admin Paneli ---
# Router admin paneli (/admin) için kimlik doğrulama anahtarı (X-Admin-Key başlığı ile gönderilir)
ADMIN_SECRET=orion-admin

# --- Veritabanı (PostgreSQL) ---
POSTGRES_HOST=router-db
POSTGRES_PORT=5432
POSTGRES_DB=orion_router
POSTGRES_USER=router_user
POSTGRES_PASSWORD=router_pass
