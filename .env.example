# ===========================================================================
# Orion Router Servisi - Ortam Değişkenleri Örneği (.env.example)
# ===========================================================================

# --- Router (bu servis) ---
ROUTER_HOST=0.0.0.0
# Uvicorn / docker-compose portu (production ve `docker compose up`).
ROUTER_PORT=20128
# Yerel hybrid dev (dev.ps1); ayarlanmazsa 20129 kullanılır.
ROUTER_DEV_PORT=20129

# --- CLI / Terminal Dili ---
# Terminal çıktılarının dili (örneğin: "tr", "en"). Yükleyici tarafından sistem dilinden otomatik algılanır.
# CLI_LANG=en


# --- Yerel Servis Adresleri ---
LLM_HOST=127.0.0.1
LLM_PORT=8080

EMBED_HOST=127.0.0.1
EMBED_PORT=8080

TTS_HOST=127.0.0.1
TTS_PORT=9000

# --- Admin Paneli ---
# Sağlayıcı API anahtarları .env'de tutulmaz; Dashboard → Key Pool üzerinden eklenir.
# Router admin paneli (/admin) için kimlik doğrulama anahtarı (X-Admin-Key başlığı ile gönderilir)
ADMIN_SECRET=orion

# --- Veritabanı (PostgreSQL) ---
# Docker Compose: router-db
# Native Dev/Prod (dev.ps1 / prod.ps1): localhost
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=orion_router
POSTGRES_USER=router_user
POSTGRES_PASSWORD=router_pass

# --- Dashboard UI ---
DASHBOARD_OUT_DIR=dashboard/out

# --- App Identification Headers ---
# OpenRouter (and other providers) demand HTTP-Referer and X-Title headers to show your app name and icon.
APP_REFERER=https://orion-ai-assistant.github.io/orion-router
APP_TITLE="Orion Router"
APP_CATEGORIES="cli-agent,cloud-agent"
